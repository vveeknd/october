Story:CreateSection("Story Farm Status")
local sLabel1 = Story:CreateLabel("State: Idle")
local sLabel2 = Story:CreateLabel("Maps: —")
local sLabel3 = Story:CreateLabel("Target Clears: —")
local sLabel4 = Story:CreateLabel("Est. Gems Today: —")

-- ── Heartbeat loops ─────────────────────────────────────────
RunService.Heartbeat:Connect(function()
    local now = tick()

    -- Auto Join single
    if ss.autoJoin and not ss.busy and (now - ss.lastJoin) >= ss.joinDelay then
        ss.lastJoin = now
        ss.busy = true
        task.spawn(function()
            local key = ss.useHighest and getHighestUnlocked().key or ss.mapKey
            joinStory(key, ss.stage, function(msg)
                pcall(function() sLabel1:Set("State: " .. msg) end)
            end)
            ss.busy = false
        end)
    end

    -- Auto Farm
    if ss.autoFarm and not ss.busy and #ss.farmMaps > 0 then
        local curKey = ss.farmMaps[ss.farmIdx]
        if not curKey then
            ss.autoFarm = false
            pcall(function() sLabel1:Set("State: Done ✅") end)
            return
        end

        ss.farmCleared[curKey] = ss.farmCleared[curKey] or 0

        if ss.farmCleared[curKey] >= ss.farmClears then
            ss.farmIdx = ss.farmIdx + 1
            curKey = ss.farmMaps[ss.farmIdx]
            if not curKey then
                ss.autoFarm = false
                pcall(function() sLabel1:Set("State: Done ✅") end)
                return
            end
            ss.farmCleared[curKey] = ss.farmCleared[curKey] or 0
        end

        if (now - ss.farmLastJoin) >= ss.joinDelay then
            ss.farmLastJoin = now
            ss.busy = true
            local capturedKey = curKey
            task.spawn(function()
                joinStory(capturedKey, 1, function(msg)
                    pcall(function() sLabel1:Set("State: " .. msg) end)
                end)
                ss.farmCleared[capturedKey] = (ss.farmCleared[capturedKey] or 0) + 1
                ss.todayPlays = ss.todayPlays + 1
                ss.busy = false
            end)
        end

        -- Update status labels
        local mapStr = {}
        for _, k in ipairs(ss.farmMaps) do
            local c = ss.farmCleared[k] or 0
            table.insert(mapStr, getMapByKey(k).title .. " " .. c .. "/" .. ss.farmClears)
        end
        local totalGems = 0
        for i = 1, ss.todayPlays do totalGems = totalGems + gemsForPlay(i) end

        pcall(function() sLabel2:Set("Maps: " .. table.concat(mapStr, " | ")) end)
        pcall(function() sLabel3:Set("Target: " .. ss.farmClears .. " clears/map") end)
        pcall(function() sLabel4:Set("Est. Gems Today: ~" .. totalGems) end)
    else
        if not ss.autoFarm and not ss.autoJoin then
            pcall(function() sLabel1:Set("State: Idle") end)
            pcall(function() sLabel2:Set("Maps: —") end)
            pcall(function() sLabel3:Set("Target Clears: —") end)
            pcall(function() sLabel4:Set("Est. Gems Today: —") end)
        end
    end
end)

