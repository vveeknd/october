local roundStart  = os.time()
local statsBefore = snapshot()

gameOver.OnClientEvent:Connect(function(wave)
    if not webhookActive then return end
    local elapsed = os.time() - roundStart
    local timeStr = string.format("%d:%02d", math.floor(elapsed / 60), elapsed % 60)
    local statsAfter = snapshot()
    sendWebhook(statsBefore, statsAfter, wave, timeStr)
    Rayfield:Notify({ Title = "October Hub", Content = "Webhook sent! Wave " .. tostring(wave), Duration = 4 })
    roundStart  = os.time()
    statsBefore = statsAfter
    if AUTO_RETRY then
        task.wait(2)
        pcall(function()
            Systems:WaitForChild("Voting", 5):WaitForChild("Vote", 5):FireServer("Retry")
        end)
    end
end)

