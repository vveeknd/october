-- ============================================================
-- HELPERS
-- ============================================================
local function getItemCount(name)
    local f = items:FindFirstChild(name)
    return f and #f:GetChildren() or 0
end

local function fmtNum(n)
    local s = tostring(math.abs(math.floor(n)))
    local result, count = "", 0
    for i = #s, 1, -1 do
        count = count + 1
        result = s:sub(i, i) .. result
        if count % 3 == 0 and i ~= 1 then result = "," .. result end
    end
    return result
end

local function fmtDiff(diff)
    local sign = diff >= 0 and "+" or "-"
    return sign .. fmtNum(math.abs(diff))
end

local function snapshot()
    return {
        coins         = currencies.Coins.Value,
        gems          = currencies.Gems.Value,
        level         = leaderstats.Level.Value,
        xp            = profile:WaitForChild("XP").Value,
        summonTickets = getItemCount("SummonTicket"),
        traitRerolls  = getItemCount("TraitReroll"),
        units         = equipped:GetChildren(),
    }
end

local function sendWebhook(before, after, wave, timeStr)
    local coinDiff   = after.coins         - before.coins
    local gemDiff    = after.gems          - before.gems
    local xpDiff     = after.xp            - before.xp
    local ticketDiff = after.summonTickets - before.summonTickets
    local rollDiff   = after.traitRerolls  - before.traitRerolls

    local rewardLines = {}
    if coinDiff   ~= 0 then table.insert(rewardLines, "**" .. fmtDiff(coinDiff)   .. " Coins**") end
    if gemDiff    ~= 0 then table.insert(rewardLines, "**" .. fmtDiff(gemDiff)    .. " Gems**") end
    if xpDiff     ~= 0 then table.insert(rewardLines, "**" .. fmtDiff(xpDiff)     .. " Exp**") end
    if ticketDiff ~= 0 then table.insert(rewardLines, "**" .. fmtDiff(ticketDiff) .. " Summon Tickets**") end
    if rollDiff   ~= 0 then table.insert(rewardLines, "**" .. fmtDiff(rollDiff)   .. " Trait Rerolls**") end
    if #rewardLines == 0 then table.insert(rewardLines, "No rewards detected") end

    local unitNames = {}
    for _, u in ipairs(after.units) do table.insert(unitNames, u.Name) end

    local embed = {
        title  = "Summon Heroes",
        color  = 5763719,
        fields = {
            { name = "Name",    value = "||" .. LP.Name .. "||",                                                         inline = false },
            { name = "Result",  value = "Endless Mode - Wave " .. tostring(wave or 0) .. " - Won\n- Time: " .. timeStr, inline = false },
            { name = "Rewards", value = table.concat(rewardLines, "\n"),                                                  inline = false },
            { name = "Balance", value = "Coins: " .. fmtNum(after.coins) .. " | Gems: " .. fmtNum(after.gems) .. " | Tickets: " .. after.summonTickets .. " | Trait RR: " .. after.traitRerolls, inline = false },
            { name = "Units",   value = #unitNames > 0 and table.concat(unitNames, ", ") or "None",                     inline = false },
        },
        footer    = { text = "Level " .. after.level .. " | " .. LP.Name },
        timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
    }

    pcall(function()
        request({
            Url     = WEBHOOK_URL,
            Method  = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body    = HttpService:JSONEncode({ embeds = { embed } }),
        })
    end)
end

