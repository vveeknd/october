local STORY_ZONE = Vector3.new(2.263615131378174, 1555.3472900390625, 27.729387283325195)

local function tweenToStoryZone()
    local char = LP.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then humanoid.WalkSpeed = 0 end

    local tween = TweenService:Create(root, TweenInfo.new(2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        CFrame = CFrame.new(STORY_ZONE)
    })
    tween:Play()
    tween.Completed:Wait()

    if humanoid then humanoid.WalkSpeed = 16 end
end

