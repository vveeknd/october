local function gemsForPlay(n)
    return math.max(100 - (n - 1) * 10, 50)
end

local function getMapByKey(key)
    for _, m in ipairs(MAPS) do
        if m.key == key then return m end
    end
    return MAPS[1]
end

local function getMapByTitle(title)
    for _, m in ipairs(MAPS) do
        if m.title == title then return m end
    end
    return MAPS[1]
end

local function getHighestUnlocked()
    local best = MAPS[1]
    pcall(function()
        local Profile = require(RS.Systems.Profile)
        local data = Profile.GetData()
        if type(data) == "table" and data.Maps then
            for _, m in ipairs(MAPS) do
                if data.Maps[m.key] then best = m end
            end
        end
    end)
    return best
end

-- Find our assigned queue Model
local function getMyQueue()
    local queues = workspace:WaitForChild("LobbyMap"):WaitForChild("Queues")
    for _, v in ipairs(queues:GetChildren()) do
        if v:IsA("Model") and v:GetAttribute("OwnerName") == LP.Name then
            return v
        end
    end
    return nil
end

-- Core join: tween to zone → wait for queue → set map/stage → launch
local function joinStory(mapKey, stageNum, statusCb)
    local function status(msg)
        if statusCb then pcall(statusCb, msg) end
    end

    -- Check if we already have a queue assigned
    local myQueue = getMyQueue()

    if not myQueue then
        -- Tween to story zone to trigger queue assignment
        status("Teleporting to Story zone...")
        tweenToStoryZone()
        task.wait(1.5)

        -- Wait up to 5s for queue to appear
        local waited = 0
        while not myQueue and waited < 5 do
            myQueue = getMyQueue()
            task.wait(0.5)
            waited = waited + 0.5
        end
    end

    if not myQueue then
        status("Failed: No queue assigned")
        Rayfield:Notify({ Title = "Story", Content = "Could not get queue. Try again.", Duration = 4 })
        return false
    end

    -- Click MapSelect StartButton to show Launcher (client-side UI step)
    pcall(function()
        local startBtn = PlayerGui.MapSelect.Container.Frame.Contents.Buttons.StartButton
        local conn
        conn = startBtn.MouseButton1Click:Connect(function() conn:Disconnect() end)
        local vum = game:GetService("VirtualInputManager")
        local pos = startBtn.AbsolutePosition + startBtn.AbsoluteSize / 2
        vum:SendMouseButtonEvent(pos.X, pos.Y, 0, true, game, 0)
        task.wait(0.05)
        vum:SendMouseButtonEvent(pos.X, pos.Y, 0, false, game, 0)
    end)

    task.wait(0.5)

    status("Launching: " .. getMapByKey(mapKey).title .. " Stage " .. stageNum)
    RS.Systems.Queue.SetQueue:FireServer(myQueue, mapKey, stageNum)
    return true
end

local function leaveStory()
    pcall(function()
        local myQueue = getMyQueue()
        if myQueue then
            RS.Systems.Queue.LeaveQueue:FireServer(myQueue)
        end
    end)
    pcall(function() RS.Systems.Queue.Leave:FireServer() end)
end

